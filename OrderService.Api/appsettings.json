{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Key": "a-super-strong-and-secret-key-that-needs-to-be-changed-in-production",
    "Issuer": "OrderService",
    "Audience": "OrderServiceUsers",
    "ExpirationMinutes": 60
  },
  "Idempotency": {
    "ResponseTtlMinutes": 60,
    "LockTtlSeconds": 30
  },
  "Redis": {
    "Configuration": "localhost:6379"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "QueueName": "order-service-events"
  }
}
